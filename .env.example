# Configuración del servidor y base de datos
PORT=3000
NODE_ENV=production

# ── Dominio público — solo para VPS + Caddy ──────────────────
# Reemplaza con tu dominio. En Railway/Render/Fly.io no aplica.
DOMAIN=tudominio.com

# ── HTTPS para camara en moviles (modo Windows directo) ──────────────────────
# Activa servidor HTTPS con cert auto-firmado (acepta aviso en navegador)
# En Docker usa Caddy (ver docker-compose.yml) — esta opcion no aplica en Docker
ENABLE_HTTPS=false
HTTPS_PORT=3443
DATABASE_PATH=database/tickets.db

# ── Cerebro IA (RAG + análisis de tickets) ───────────────────────────────
# Opciones: claude | openai | gemini | ollama | none
LLM_PROVIDER=none
# API key del proveedor elegido (no requerida para ollama)
LLM_API_KEY=
# Modelo específico (opcional — usa el default del proveedor si se omite)
#   claude  → claude-sonnet-4-6
#   openai  → gpt-4o-mini
#   gemini  → gemini-1.5-flash
#   ollama  → llama3
LLM_MODEL=
# Solo para Ollama self-hosted:
LLM_BASE_URL=http://localhost:11434

# Google Gemini API
GEMINI_API_KEY=

# ── Integración de Google Sheets ─────────────────────────────────────────
# Módulo Farmacias FOMAG (URL del CSV publicado)
GOOGLE_SHEETS_CSV_URL=
# URL del Apps Script para escritura (opcional)
GOOGLE_APPS_SCRIPT_URL=

# Registros IT (Google Sheets Apps Script URL y Sheet URL)
REGISTROS_SCRIPT_URL=
REGISTROS_SHEET_URL=

# ── Toggles de background workers ────────────────────────────────────────
# Pon en 'true' para desactivar los servicios en segundo plano correspondientes
DISABLE_WHATSAPP=false
DISABLE_INACTIVITY_MONITOR=false
DISABLE_OFFLINE_CHECKER=false
# En producción con Caddy/reverse-proxy externo: poner true
DISABLE_TUNNEL=true

# ── WhatsApp ──────────────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=cambia_este_token_secreto
IT_WHATSAPP_NUMBER=573000000000
IT_PHONE=573000000000

# ── Sistema de Requerimientos Medivalle ──────────────────────────────────
REQ_GMAIL_USER=gestion.medivallesf@gmail.com
REQ_GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
REQ_ADMIN_SECRET=genera_un_string_aleatorio_largo_aqui
REQ_ADMIN_USER=GESTION
REQ_ADMIN_PASS=cambia_esta_clave_en_produccion

# ── Calendario de Reuniones (Google Meet) ───────────────────────────────────
GOOGLE_CALENDAR_ID=xxx@group.calendar.google.com
# Una de las dos opciones para credenciales:
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./config/service-account.json
# GOOGLE_SERVICE_ACCOUNT_KEY_JSON={"type":"service_account",...}
