{
  "name": "it-tickets",
  "version": "1.2.0",
  "description": "Sistema de Tickets IT con WhatsApp y Panel Web",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "test": "node test-ci.mjs",
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build:agent": "cd agent && npm install && npm run build",
