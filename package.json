    "docx": "^9.7.0",
    "dotenv": "^16.4.0",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "googleapis": "^173.0.0",
    "multer": "^2.1.1",
    "nodemailer": "^9.0.1",
    "qrcode": "^1.5.4",
    "selfsigned": "^5.5.0",
    "whatsapp-web.js": "^1.34.7"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
